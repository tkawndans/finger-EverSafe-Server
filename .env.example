# 로컬용: 이 파일을 복사해 `.env` 로 저장한 뒤 값을 채우세요.
# `.env` 는 Git에 커밋되지 않습니다 (.gitignore).

# PORT=3000

# 공유 비밀: headful 전환(POST /browser/headful 의 X-Browser-Admin-Token) — 추후 API body 인코딩/디코딩 키로도 사용 가능
# BROWSER_ADMIN_TOKEN=

# EverSafe VM 스크립트 (선택, 미설정 시 ever-safe/EverSafe.txt)
# EVERSAFE_TXT_PATH=

# 웜 세션: 설정 시 기동 후 해당 URL로 이동·VM 주입 → POST /evaluate/warm 로 XHR만
# WARM_START_URL=

# evaluate/warm 디버그: 디코드·XHR 본문 미리보기를 터미널에 출력(민감 정보 주의)
# LOG_EVALUATE_WARM_PAYLOAD=1
