# 로컬용: 이 파일을 복사해 `.env` 로 저장한 뒤 값을 채우세요.
# `.env` 는 Git에 커밋되지 않습니다 (.gitignore).

# (선택) POST /evaluate/warm 응답 헤더 E-server-Build — 서버/도커 슬롯 구분용(미설정 시 BUILD_ID 도 사용)
# EVER_SAFE_BUILD_ID=

# PORT=3000

# 공유 비밀: headful 전환(POST /browser/headful 의 X-Browser-Admin-Token) — 추후 API body 인코딩/디코딩 키로도 사용 가능
# BROWSER_ADMIN_TOKEN=

# EverSafe VM 스크립트 (선택, 미설정 시 ever-safe/EverSafe.txt)
# EVERSAFE_TXT_PATH=

# 웜 세션: 설정 시 기동 후 해당 URL로 이동·VM 주입 → POST /evaluate/warm 로 XHR만
# WARM_START_URL=

# 평가/헬스 페이로드·응답 로그(기본: 기록). 0 만 넣으면 터미널+파일 로그 끔. → process.cwd()/log/serverlog.log (한국 자정마다 serverlog-YYYYMMDD.log 로 롤)
# LOG_EVALUATE_WARM_PAYLOAD=0
# 보관 주기(일): 오래된 serverlog-*.log 등만 삭제. 미설정=10, 0=삭제 안 함
# LOG_RETENTION_DAYS=10
