# 로컬용: 이 파일을 복사해 `.env` 로 저장한 뒤 값을 채우세요.
# `.env` 는 Git에 커밋되지 않습니다 (.gitignore).

# (선택) POST /evaluate/warm 응답 헤더 E-server-Build — 서버/도커 슬롯 구분용(미설정 시 BUILD_ID 도 사용)
# EVER_SAFE_BUILD_ID=

# PORT=3000

# 공유 비밀: headful 전환(POST /browser/headful 의 X-Browser-Admin-Token) — 추후 API body 인코딩/디코딩 키로도 사용 가능
# BROWSER_ADMIN_TOKEN=

# EverSafe VM 스크립트 (선택, 미설정 시 ever-safe/EverSafe.txt)
# EVERSAFE_TXT_PATH=

# 웜 세션: 설정 시 기동 후 해당 URL로 이동·VM 주입 → POST /evaluate/warm 로 XHR만
# WARM_START_URL=
# 워밍 페이지의 메인 프레임 네비게이션은 **WARM_START_URL 정규화 일치할 때만 허용** 이 기본 동작이다.
# 그 외(JS location.assign/replace/href·history.pushState/replaceState·meta refresh·서버 302 등)는 모두 차단되며,
# JS 로 잡히지 않는 경로(window.location = X 등)는 인터셉션 단에서 204 No Content 응답으로 원래 문서를 유지한다.

# 진단/차단용: 부분 문자열(콤마 구분) 매칭되는 요청은 빈 200(스크립트)/204(문서)로 응답해 로딩 자체 차단.
# 진단 로그(`[warm-lock] BLOCKED main nav → ... | initiator: ...`)에서 redirect 트리거 스크립트/리소스를 식별 후 여기에 추가.
# WARM_LOCK_BLOCK_REQUEST_URL_PATTERNS=/inbank/ws/pr/ma/PRMA01001.do

# 평가/헬스 페이로드·응답 로그(기본: 기록). 0 만 넣으면 터미널+파일 로그 끔. → process.cwd()/log/serverlog.log (한국 자정마다 serverlog-YYYYMMDD.log 로 롤)
# LOG_EVALUATE_WARM_PAYLOAD=0
# 보관 주기(일): 오래된 serverlog-*.log 등만 삭제. 미설정=5, 0=삭제 안 함
# LOG_RETENTION_DAYS=5
